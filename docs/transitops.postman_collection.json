{
  "info": {
    "name": "TransitOps API",
    "description": "Smart Transport Operations Platform API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Login", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"email\": \"fm@transitops.com\", \"password\": \"password123\"}" }, "url": { "raw": "http://localhost:3001/auth/login", "host": ["http://localhost:3001"], "path": ["auth", "login"] } } },
        { "name": "Get Me", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/auth/me", "host": ["http://localhost:3001"], "path": ["auth", "me"] } } }
      ]
    },
    {
      "name": "Vehicles",
      "item": [
        { "name": "List Vehicles", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/vehicles", "host": ["http://localhost:3001"], "path": ["vehicles"] } } },
        { "name": "Create Vehicle", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"registrationNumber\": \"Van-06\", \"name\": \"New Van\", \"model\": \"2024\", \"type\": \"VAN\", \"maxLoadCapacity\": 800, \"acquisitionCost\": 40000}" }, "url": { "raw": "http://localhost:3001/vehicles", "host": ["http://localhost:3001"], "path": ["vehicles"] } } }
      ]
    },
    {
      "name": "Drivers",
      "item": [
        { "name": "List Drivers", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/drivers", "host": ["http://localhost:3001"], "path": ["drivers"] } } }
      ]
    },
    {
      "name": "Trips",
      "item": [
        { "name": "Create Trip (DRAFT)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"source\": \"Warehouse A\", \"destination\": \"Site B\", \"vehicleId\": 1, \"driverId\": 1, \"cargoWeight\": 450, \"plannedDistance\": 120}" }, "url": { "raw": "http://localhost:3001/trips", "host": ["http://localhost:3001"], "path": ["trips"] } } },
        { "name": "Dispatch Trip", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/trips/{{tripId}}/dispatch", "host": ["http://localhost:3001"], "path": ["trips", "{{tripId}}", "dispatch"] } } },
        { "name": "Complete Trip", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"endOdometer\": 15150, \"fuelConsumed\": 12}" }, "url": { "raw": "http://localhost:3001/trips/{{tripId}}/complete", "host": ["http://localhost:3001"], "path": ["trips", "{{tripId}}", "complete"] } } },
        { "name": "Over-Capacity (expect 400)", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{token}}" }], "body": { "mode": "raw", "raw": "{\"source\": \"A\", \"destination\": \"B\", \"vehicleId\": 1, \"driverId\": 1, \"cargoWeight\": 9999, \"plannedDistance\": 10}" }, "url": { "raw": "http://localhost:3001/trips/{{tripId}}/dispatch", "host": ["http://localhost:3001"], "path": ["trips", "{{tripId}}", "dispatch"] } } }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        { "name": "Get KPIs", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/dashboard/kpis", "host": ["http://localhost:3001"], "path": ["dashboard", "kpis"] } } },
        { "name": "Export CSV", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": { "raw": "http://localhost:3001/reports/export.csv", "host": ["http://localhost:3001"], "path": ["reports", "export.csv"] } } }
      ]
    }
  ]
}
